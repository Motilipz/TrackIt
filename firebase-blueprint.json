{
  "entities": {
    "StudyLog": {
      "title": "StudyLog",
      "description": "A single entry of study time for CAT preparation.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the log entry." },
        "userId": { "type": "string", "description": "The UID of the user who logged the time." },
        "category": { "type": "string", "description": "The category of study." },
        "duration": { "type": "number", "description": "Duration in minutes." },
        "date": { "type": "string", "format": "date-time", "description": "The date of the study session." },
        "notes": { "type": "string", "description": "Optional notes for the session." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the log was created." },
        "startTime": { "type": "string", "description": "Start time in HH:MM format." },
        "endTime": { "type": "string", "description": "End time in HH:MM format." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the log was last updated." }
      },
      "required": ["userId", "category", "duration", "date", "createdAt"]
    },
    "UserSettings": {
      "title": "UserSettings",
      "description": "User-specific settings like custom categories or goals.",
      "type": "object",
      "properties": {
        "list": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of custom study categories."
        },
        "daily": { "type": "number", "description": "Daily study goal in minutes." },
        "weekly": { "type": "number", "description": "Weekly study goal in minutes." }
      }
    },
    "ReadingLog": {
      "title": "ReadingLog",
      "description": "An entry for a reading session in the Reading Velocity Engine.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "wordCount": { "type": "number" },
        "duration": { "type": "number" },
        "wpm": { "type": "number" },
        "gradeLevel": { "type": "number" },
        "comprehensionSummary": { "type": "string" },
        "domain": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "excerpt", "wordCount", "duration", "wpm", "date", "createdAt"]
    },
    "DailyTask": {
      "title": "DailyTask",
      "description": "A single daily action item/planned task.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "description": "Date of the task in YYYY-MM-DD format" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "is_frog": { "type": "boolean" },
        "status": { "type": "string", "enum": ["pending", "done", "failed"] },
        "failureReason": { "type": "string" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "title", "category", "is_frog", "status", "createdAt"]
    },
    "AccountabilitySettings": {
      "title": "AccountabilitySettings",
      "description": "Risk parameters, burn rates, exam date, email targets, and restricted websites.",
      "type": "object",
      "properties": {
        "stakesEnabled": { "type": "boolean" },
        "stakesAmount": { "type": "number" },
        "antiCharity": { "type": "string" },
        "boardEmails": { "type": "string" },
        "burnGoalHours": { "type": "number" },
        "examDate": { "type": "string" },
        "restrictionsEnabled": { "type": "boolean" },
        "restrictedSites": { "type": "string" }
      },
      "required": ["stakesEnabled", "stakesAmount", "antiCharity", "boardEmails", "burnGoalHours", "examDate", "restrictionsEnabled", "restrictedSites"]
    },
    "ProofVaultItem": {
      "title": "ProofVaultItem",
      "description": "Messy scratchpad image or external sheet logs verifying raw study completion.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "taskTitle": { "type": "string" },
        "category": { "type": "string" },
        "proofNotes": { "type": "string" },
        "imageFileName": { "type": "string" },
        "imageDataUrl": { "type": "string" },
        "fileLink": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["taskTitle", "category", "proofNotes", "imageFileName", "fileLink", "createdAt"]
    },
    "ArenaRanking": {
      "title": "ArenaRanking",
      "description": "Multi-user engagement data for the public competitive leaderboard.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "totalHours": { "type": "number" },
        "streak": { "type": "number" },
        "tasksCompleted": { "type": "number" },
        "wpm": { "type": "number" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "displayName", "photoURL", "totalHours", "streak", "tasksCompleted", "wpm", "lastActive"]
    }
  },
  "firestore": {
    "/users/{userId}/logs/{logId}": {
      "schema": "StudyLog",
      "description": "User's study logs."
    },
    "/users/{userId}/readingLogs/{logId}": {
      "schema": "ReadingLog",
      "description": "User's reading velocity logs."
    },
    "/users/{userId}/settings/{settingId}": {
      "schema": "UserSettings",
      "description": "User's settings and configurations."
    },
    "/users/{userId}/settings/accountability": {
      "schema": "AccountabilitySettings",
      "description": "User's high stakes risk parameters."
    },
    "/users/{userId}/dailyTasks/{taskId}": {
      "schema": "DailyTask",
      "description": "User's daily tasks and action items."
    },
    "/users/{userId}/proofVault/{proofId}": {
      "schema": "ProofVaultItem",
      "description": "Evidence uploaded of messy scratchpad work."
    },
    "/arena_rankings/{userId}": {
      "schema": "ArenaRanking",
      "description": "Public multi-user competitive metrics on the Arena Board."
    }
  }
}
