rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}/logs/{logId}
    // Document ID: auto-generated or logId
    // Fields:
    //   - userId: string (required, matches userId in path)
    //   - category: string (required)
    //   - duration: number (required, positive)
    //   - date: timestamp (required)
    //   - notes: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: /users/{userId}/settings/{settingId}
    // Document ID: categories or goals
    // Fields:
    //   - list: list of strings (required for categories)
    //   - daily: number (required for goals)
    //   - weekly: number (required for goals)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['userId', 'category', 'duration', 'date', 'createdAt']) &&
             data.userId is string &&
             data.category is string && data.category.size() > 0 && data.category.size() < 100 &&
             data.duration is number && data.duration > 0 &&
             data.date is timestamp &&
             data.createdAt is timestamp &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000)) &&
             (!('startTime' in data) || (data.startTime is string || data.startTime == null)) &&
             (!('endTime' in data) || (data.endTime is string || data.endTime == null)) &&
             (!('rating' in data) || (data.rating is number && data.rating >= 0 && data.rating <= 5)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp));
    }

    function isValidSettings(data, settingId) {
      return (settingId == 'categories' && data.keys().hasAll(['list']) && data.list is list && data.list.size() <= 50) ||
             (settingId == 'goals' && data.keys().hasAll(['daily', 'weekly']) && data.daily is number && data.weekly is number) ||
             (settingId == 'accountability' && data.keys().hasAll(['stakesEnabled', 'stakesAmount', 'antiCharity', 'boardEmails', 'burnGoalHours', 'examDate', 'restrictionsEnabled', 'restrictedSites']) && 
              data.stakesEnabled is bool && data.stakesAmount is number && 
              data.antiCharity is string && data.antiCharity.size() <= 200 &&
              data.boardEmails is string && data.boardEmails.size() <= 500 &&
              data.burnGoalHours is number && 
              data.examDate is string && data.examDate.size() <= 20 &&
              data.restrictionsEnabled is bool && 
              data.restrictedSites is string && data.restrictedSites.size() <= 2000 &&
              (!('lastSentAuditWeek' in data) || (data.lastSentAuditWeek is string && data.lastSentAuditWeek.size() <= 50))) ||
             (settingId == 'milestone' && data.keys().hasAll(['date', 'label']) && data.date is string && data.date.size() <= 20 && data.label is string && data.label.size() <= 100);
    }

    function isValidReadingLog(data) {
      return data.keys().hasAll(['userId', 'title', 'excerpt', 'wordCount', 'duration', 'wpm', 'gradeLevel', 'comprehensionSummary', 'domain', 'date', 'createdAt']) &&
             data.userId is string &&
             data.title is string && data.title.size() <= 200 &&
             data.excerpt is string && data.excerpt.size() <= 50000 &&
             data.wordCount is number &&
             data.duration is number &&
             data.wpm is number &&
             data.gradeLevel is number &&
             data.comprehensionSummary is string && data.comprehensionSummary.size() <= 2000 &&
             data.domain is string &&
             data.date is timestamp &&
             data.createdAt is timestamp;
    }

    function isValidVocabulary(data) {
      return data.keys().hasAll(['userId', 'word', 'date']) &&
             data.userId is string &&
             data.word is string && data.word.size() > 0 && data.word.size() <= 200 &&
             data.date is timestamp;
    }

    function isValidDailyTask(data) {
      return data.keys().hasAll(['userId', 'date', 'title', 'category', 'is_frog', 'status', 'createdAt', 'estimatedDuration']) &&
             data.userId is string &&
             data.date is string && data.date.size() == 10 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 20 &&
             data.is_frog is bool &&
             data.status is string && (data.status == 'pending' || data.status == 'done' || data.status == 'failed') &&
             data.estimatedDuration is number &&
             (!('proofOfWork' in data) || (data.proofOfWork is string && data.proofOfWork.size() <= 500)) &&
             (!('failureReason' in data) || (data.failureReason is string && data.failureReason.size() <= 1000)) &&
             (!('order' in data) || (data.order is number)) &&
             data.createdAt is timestamp;
    }

    function isValidProofVault(data) {
      return data.keys().hasAll(['taskTitle', 'category', 'proofNotes', 'imageFileName', 'fileLink', 'createdAt']) &&
             data.taskTitle is string && data.taskTitle.size() <= 300 &&
             data.category is string && data.category.size() <= 100 &&
             data.proofNotes is string && data.proofNotes.size() <= 2000 &&
             data.imageFileName is string && data.imageFileName.size() <= 500 &&
             (!('imageDataUrl' in data) || (data.imageDataUrl is string && data.imageDataUrl.size() <= 1500000)) &&
             data.fileLink is string && data.fileLink.size() <= 1000 &&
             data.createdAt is string && data.createdAt.size() <= 100;
    }

    function isValidArenaRanking(data) {
      return data.keys().hasAll(['userId', 'displayName', 'photoURL', 'totalHours', 'streak', 'tasksCompleted', 'wpm', 'lastActive']) &&
             data.userId is string &&
             data.displayName is string && data.displayName.size() <= 200 &&
             data.photoURL is string && data.photoURL.size() <= 1000 &&
             data.totalHours is number &&
             data.streak is number &&
             data.tasksCompleted is number &&
             data.wpm is number &&
             data.lastActive is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // User data structure
    match /users/{userId} {
      // Allow user to read their own document (even if empty)
      allow read: if isOwner(userId);
      
      // User logs
      match /logs/{logId} {
        allow read: if isOwner(userId) || (isAuthenticated() && resource.data.isVerified == true);
        allow delete: if isOwner(userId) || (isAuthenticated() && resource.data.isVerified == true);
        allow create: if isOwner(userId) && isValidLog(request.resource.data);
        allow update: if (isOwner(userId) && isValidLog(request.resource.data)) || (isAuthenticated() && resource.data.isVerified == true);
      }

      // User settings
      match /settings/{settingId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidSettings(request.resource.data, settingId);
        allow delete: if isOwner(userId);
      }

      // Reading logs
      match /readingLogs/{logId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidReadingLog(request.resource.data);
      }

      // Vocabulary
      match /vocabulary/{vocabId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidVocabulary(request.resource.data);
      }

      // Daily tasks
      match /dailyTasks/{taskId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidDailyTask(request.resource.data);
      }

      // Proof Vault
      match /proofVault/{proofId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidProofVault(request.resource.data);
      }
    }

    // Public Arena / Leaderboard rankings
    match /arena_rankings/{userId} {
      allow read: if isAuthenticated();
      allow create: if (isOwner(userId) || (isAuthenticated() && userId.matches('^bot_.*'))) && isValidArenaRanking(request.resource.data);
      allow update: if (
        isOwner(userId) || 
        (isAuthenticated() && userId.matches('^bot_.*')) ||
        (
          isAuthenticated() && 
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.displayName == resource.data.displayName &&
          request.resource.data.photoURL == resource.data.photoURL &&
          request.resource.data.totalHours == resource.data.totalHours &&
          request.resource.data.streak == resource.data.streak &&
          request.resource.data.tasksCompleted == resource.data.tasksCompleted &&
          request.resource.data.wpm == resource.data.wpm &&
          request.resource.data.lastActive == resource.data.lastActive
        )
      ) && isValidArenaRanking(request.resource.data);
      allow delete: if isOwner(userId) || (isAuthenticated() && userId.matches('^bot_.*'));
    }
  }
}
